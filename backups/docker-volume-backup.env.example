# =============================================================================
# PPSA - Backup Agent Configuration
# =============================================================================
# Copy this to docker-volume-backup.env and fill in your values.

# Schedule (cron format): daily at 3 AM
BACKUP_CRON_EXPRESSION=0 3 * * *

# Retention: keep backups for 7 days
BACKUP_RETENTION_DAYS=7

# Backup filename template
BACKUP_FILENAME=ppsa-{{ .ContainerName }}-{{ .Now | date "20060102-150405" }}.tar.gz

# Optional: Discord notifications
# NOTIFY_URLS=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Optional: Upload to S3-compatible storage
# AWS_S3_BUCKET_NAME=my-ppsa-backups
# AWS_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_PREFIX=ppsa/

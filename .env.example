# =============================================================================
# PPSA - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Set these via the web UI Config tab.
# =============================================================================

# --- Palworld Server ---
SERVER_NAME=My Palworld Server
SERVER_DESCRIPTION=Welcome to my server!
SERVER_PASSWORD=
ADMIN_PASSWORD=changeme
MAX_PLAYERS=16
PORT=8211
RCON_ENABLED=true
RCON_PORT=25575
RESTAPI_ENABLED=true
RESTAPI_PORT=8212
MULTITHREADING=true
COMMUNITY=false
TZ=UTC

# --- Backup ---
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=7

# --- Discord Notifications (optional) ---
DISCORD_WEBHOOK_URL=

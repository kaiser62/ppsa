# Build output
build/
*.img
*.img.xz
*.img.xz.sha256

# Local WireGuard credentials (drop your wg-easy creds here, gitignored)
# Copy wireguard.local.json.example to wireguard.local.json and fill in.
# CI builds never read this file; only local builds via Start-PpsaBuilder.ps1.
wireguard.local.json

# Local NetBird enrollment config (management URL + reusable setup key).
# Copy netbird.local.json.example to netbird.local.json and fill in.
# CI builds read PPSA_NB_MANAGEMENT_URL / PPSA_NB_SETUP_KEY secrets instead.
netbird.local.json

# Local NetBird TEST-PEER config (dedicated key, VM identities only — never
# the appliance's own key). Copy netbird.test.json.example to
# netbird.test.json and fill in. See docs/netbird-test-peer.md.
netbird.test.json

# Local hardcoded WireGuard failsafe config (raw wg0.conf, gitignored — the
# CI build reads the base64'd equivalent from the PPSA_WG_FALLBACK_CONF_B64
# repo secret instead, never from this file).
wireguard-fallback.local.conf

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
env/
venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Local handoff/scratch docs — may contain secrets (setup keys, PATs,
# admin passwords). Never commit.
deepseek*.md
netbird-deployment.cont.md

# Docker
.docker/

# Git
*.orig
*.png
.playwright-mcp/
.vagrant-mcp/
backups/

# Smoke test logs (raw command output from ppsa-smoke-test.py)
smoke-test-logs/

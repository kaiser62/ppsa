# =============================================================================
# PPSA - Palworld Server Settings
# =============================================================================
# These environment variables are passed to the palworld-server-docker container.
# See https://palworld-server-docker.loef.dev/ for full documentation.

# Server identity
SERVER_NAME=My PPSA Server
SERVER_DESCRIPTION=A Portable Palworld Server Appliance

# Access
SERVER_PASSWORD=
ADMIN_PASSWORD=changeme

# Performance
MAX_PLAYERS=16
MULTITHREADING=true

# Networking
PORT=8211
RCON_ENABLED=true
RCON_PORT=25575
RESTAPI_ENABLED=true
RESTAPI_PORT=8212
QUERY_PORT=27015

# Discovery
COMMUNITY=false
PUBLIC_IP=
PUBLIC_PORT=

# Gameplay (see official docs for full list)
DIFFICULTY=None
DAY_TIME_SPEED_RATE=1.000000
NIGHT_TIME_SPEED_RATE=1.000000
EXP_RATE=1.000000
PAL_CAPTURE_RATE=1.000000
PAL_SPAWN_NUM_RATE=1.000000
PAL_DAMAGE_RATE_ATTACK=1.000000
PAL_DAMAGE_RATE_DEFENSE=1.000000
PLAYER_DAMAGE_RATE_ATTACK=1.000000
PLAYER_DAMAGE_RATE_DEFENSE=1.000000
PLAYER_STOMACH_DECREASE_RATE=1.000000
PLAYER_STAMINA_DECREASE_RATE=1.000000
AUTO_HP_RECOVERY_RATE=1.000000
ENABLE_INVADER_ENEMY=true
ACTIVE_UNKO=0

# Auto-save
SAVE_INTERVAL=30
BACKUP_ENABLED=true
BACKUP_INTERVAL=5400
BACKUP_NUM=5
